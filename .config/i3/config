# Please see https://i3wm.org/docs/userguide.html for a complete reference!

exec_always --no-startup-id fc-cache -fv

set $mod Mod4
floating_modifier Mod1

font pango:Google Sans Code Proportional 15

exec_always --no-startup-id xrandr --output DP-0 --mode 1920x1080 --rate 240 --scale-from 1440x960
exec_always --no-startup-id xrandr --output DP-1 --mode 1920x1080 --rate 240 --scale-from 1440x960
exec_always --no-startup-id xrandr --output DP-2 --mode 1920x1080 --rate 240 --scale-from 1440x960
exec_always --no-startup-id xrandr --output eDP-0 --off
exec_always --no-startup-id xrandr --output eDP-1 --off
exec_always --no-startup-id xrandr --output eDP-2 --off

exec --no-startup-id rdex-autostart --autostart --environment i3
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
exec --no-startup-id nm-applet

set $refresh_i3status killall -SIGUSR1 i3status
bindsym $mod+p exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym $mod+o exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status

bindsym $mod+w exec --no-startup-id xrandr --output eDP-0 --mode 1440x960 --rate 60
bindsym $mod+s exec --no-startup-id xrandr --output eDP-1 --mode 1440x960 --rate 60
bindsym $mod+x exec --no-startup-id xrandr --output eDP-2 --mode 1440x960 --rate 60

bindsym $mod+Return exec alacritty
bindsym $mod+d exec "rofi -modi drun,run -show drun"

bindsym $mod+Shift+q kill
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+r restart

bar {
  position top
  mode hide
  colors {
    background #000000
    statusline #FFFFFF
    separator  #000000

    focused_workspace  #83CAFA #51A2DA #FFFFFF
    active_workspace   #3C6EB4 #294172 #FFFFFF
    inactive_workspace #8C8C8C #4C4C4C #888888
    urgent_workspace   #EC69A0 #DB3279 #FFFFFF
    binding_mode       #b691d3 #A07CBC #FFFFFF
  }
  status_command i3status --config ~/.config/i3/bar.conf
}

default_border none
default_floating_border none
for_window [class="*"] border none
bindsym $mod+1 workspace number "1"
bindsym $mod+2 workspace number "2"
bindsym $mod+3 workspace number "3"
bindsym $mod+4 workspace number "4"
bindsym $mod+5 workspace number "5"
bindsym $mod+6 workspace number "6"
bindsym $mod+7 workspace number "7"
bindsym $mod+8 workspace number "8"
bindsym $mod+9 workspace number "9"
bindsym $mod+Shift+1 move container to workspace number "1"
bindsym $mod+Shift+2 move container to workspace number "2"
bindsym $mod+Shift+3 move container to workspace number "3"
bindsym $mod+Shift+4 move container to workspace number "4"
bindsym $mod+Shift+5 move container to workspace number "5"
bindsym $mod+Shift+6 move container to workspace number "6"
bindsym $mod+Shift+7 move container to workspace number "7"
bindsym $mod+Shift+8 move container to workspace number "8"
bindsym $mod+Shift+9 move container to workspace number "9"
